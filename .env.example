# HKVM-RAG ICDE 2027 Artifact — Environment Configuration
#
# Copy this file to .env and fill in your values.
# The .env file is gitignored and will never be committed.

# DeepSeek API key. Required ONLY if you intend to regenerate LLM extraction
# caches from scratch. The artifact ships with pre-extracted caches under
# data/llm_extraction_caches/, so paper-evidence verification and fixed-substrate
# reruns do NOT require this key.
DEEPSEEK_API_KEY=YOUR_DEEPSEEK_API_KEY

# Optional: Hugging Face token for downloading model weights (Contriever,
# ColBERTv2) when running dense-retrieval rows. Not needed for
# fixed-substrate structured-only reruns or paper-evidence verification.
# HF_TOKEN=YOUR_HF_TOKEN
