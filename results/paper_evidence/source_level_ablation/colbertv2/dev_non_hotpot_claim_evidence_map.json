  "unsafe_claims": [
    {
      "claim": "The earlier WHG-KV feature-form ablation proves source-level superiority.",
      "reason": "That ablation only varies feature forms inside the WHG-KV controller, not alternative structured sources."
    },
    {
      "claim": "Alternative structured sources received learned Phase1C calibration.",
      "reason": "hyper_rag, static_hg, and weighted_kg_ppr train-side inputs are direct cache-derived retrieval predictions; WHG-KV uses the existing OOF learned calibration row."
    },
    {
      "claim": "No source-level superiority should be stated if WHG-KV does not beat alternatives with a positive matched bootstrap interval.",
      "reason": "The source-level claim depends on this export, not on prior Phase1D rows alone."
    }
  ]
